rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /consultationRequests/{requestId} {
      allow create: if isValidConsultationRequest();
      allow read, update, delete: if false;
    }

    function isValidConsultationRequest() {
      return request.resource.data.keys().hasOnly([
          'name',
          'phone',
          'email',
          'need',
          'preferredTime',
          'sourcePath',
          'userAgent',
          'status',
          'requestedAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 80
        && request.resource.data.phone is string
        && request.resource.data.phone.size() >= 6
        && request.resource.data.phone.size() <= 40
        && request.resource.data.email is string
        && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        && request.resource.data.email.size() <= 120
        && request.resource.data.need is string
        && request.resource.data.need.size() >= 1
        && request.resource.data.need.size() <= 1200
        && request.resource.data.preferredTime is string
        && request.resource.data.preferredTime.size() >= 10
        && request.resource.data.preferredTime.size() <= 40
        && request.resource.data.sourcePath is string
        && request.resource.data.sourcePath.size() <= 200
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() <= 300
        && request.resource.data.status == 'new'
        && request.resource.data.requestedAt == request.time;
    }
  }
}
